# Vendored binaries — fetched and staged at runtime by Install-Prereqs.ps1
tools/bin/
tools/kev/
tools/python/
# PS modules are committed directly (small, no build step required)

# Oversized executables — excluded (exceed GitHub 100 MB limit); restored at runtime
# by Restore-PingCastle.ps1 and Restore-PurpleKnight.ps1 via Install-Prereqs.ps1
# Everything else in tools/bin is committed directly.
!tools/bin/Active_Directory_Security_Self_Assessment_v1.4.pdf
!tools/bin/appsettings.console.json
!tools/bin/certipy
!tools/bin/Group3r.exe
!tools/bin/license.rtf
!tools/bin/Restore-PingCastle.ps1
!tools/bin/SharpHound.exe
!tools/bin/SharpHound.exe.config
!tools/bin/SharpHound.pdb
!tools/bin/SharpHound.ps1
!tools/bin/PingCastle.exe.zip.partaa
!tools/bin/PingCastle.exe.zip.partab
!tools/bin/PingCastleAutoUpdater.exe.zip
!tools/bin/PK_Community_5.0/
!tools/bin/PK_Community_5.0/**
# Re-exclude the oversized assembled executables (restored at runtime, not committed)
tools/bin/PingCastle.exe
tools/bin/PingCastleAutoUpdater.exe
tools/bin/PingCastle.exe.zip
tools/bin/PK_Community_5.0/PurpleKnight.exe

# Raw run artifacts (large zips / XML)
output/runs/*/artifacts/

# Do NOT ignore output/runs/*/  — JSON records are the source of truth and must be committed
!output/runs/
!output/runs/**/*.json

# Local config overrides
config/settings.local.psd1
config/targets.psd1

# PurpleKnight exports — sensitive AD security data; store locally, do not commit
output/purpleknight/*.csv
output/purpleknight/*.html
output/purpleknight/*.xlsx
!output/purpleknight/.gitkeep

# OS / editor noise
.DS_Store
Thumbs.db
*.bak
*.tmp
